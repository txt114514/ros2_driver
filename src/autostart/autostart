#!/bin/bash
### BEGIN INIT INFO
# Provides:          ROBOCON autostart
# Author:           Nagisa 2964793117@qq.com
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Description:       Auto-launch ROS2 driver and LIO-SAM containers with Docker Compose
### END INIT INFO

# 配置文件路径
LOG_FILE="/home/up70/ros2_ws/src/autostart/startlog.log"
LOCK_FILE="/home/up70/ros2_ws/src/autostart/startlog.lock"

# 项目目录定义
VOXEL_SLAM_DIR="/home/up70/slam_docker/VoxelSlam/.devcontainer"
LIO_SAM_DIR="/home/up70/slam_docker/lio_sam/.devcontainer"
POINT_LIO_DIR="/home/up70/slam_docker/point_lio/.devcontainer"
ros2_ws_DIR="/home/up70/ros2_ws/.devcontainer"

init_log() {
    mkdir -p "$(dirname "$LOG_FILE")"
    touch "$LOG_FILE"
    # 使用当前用户（推荐）
    chown $(id -u):$(id -g) "$LOG_FILE"
    chmod 644 "$LOG_FILE"
}

# 日志记录函数
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "${LOG_FILE}"
}

# 清理现有容器
clean_containers() {
    log "🧹 清理现有容器..."
    docker rm -f ros2driver-container lio_sam_container voxel_slam_container point_lio_container 2>/dev/null >> "${LOG_FILE}" 2>&1
    if [ $? -eq 0 ]; then
        log "✅ 容器已成功移除"
    else
        log "⚠️  没有找到要移除的容器或发生错误"
    fi
}

# 启动LIO-SAM容器
start_lio_sam() {
    log "🚀 启动LIO-SAM容器..."
    pushd "${LIO_SAM_DIR}" >/dev/null || { log "❌ 无法进入目录: ${LIO_SAM_DIR}"; return 1; }
    
    # 后台启动容器并记录日志
    docker compose up -d >> "${LOG_FILE}" 2>&1
    
    # 等待容器启动（最长30秒）
    local timeout=30
    while (( timeout-- > 0 )); do
        if docker ps --filter "name=lio_sam_container" --format "{{.Status}}" | grep -q "Up"; then
            log "✅ LIO-SAM容器已启动"
            LIO_CONTAINER_ID=$(docker ps -qf "name=lio_sam_container")
            log "📌 容器ID: ${LIO_CONTAINER_ID}"
            popd >/dev/null
            return 0
        fi
        sleep 1
    done
    
    log "❌ LIO-SAM容器启动超时，查看日志: docker compose logs"
    docker compose logs >> "${LOG_FILE}" 2>&1
    popd >/dev/null
    return 1
}

# 启动Point LIO容器
start_point_lio() {
    log "🚀 启动Point LIO容器..."
    pushd "${POINT_LIO_DIR}" >/dev/null || { log "❌ 无法进入目录: ${POINT_LIO_DIR}"; return 1; }
    # 后台启动容器并记录日志
    docker compose up -d >> "${LOG_FILE}" 2>&1
