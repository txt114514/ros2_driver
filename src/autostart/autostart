}

# 启动VoxelSlam容器
start_voxel_slam() {
    log "🚀 启动VoxelSlam容器..."
    pushd "${VOXEL_SLAM_DIR}" >/dev/null || { log "❌ 无法进入目录: ${VOXEL_SLAM_DIR}"; return 1; }
    
    # 后台启动容器并记录日志
    docker compose -f ./loc.yaml up -d >> "${LOG_FILE}" 2>&1
    # docker compose up -d >> "${LOG_FILE}" 2>&1

    # 等待容器启动（最长30秒）
    local timeout=30
    while (( timeout-- > 0 )); do
        if docker ps --filter "name=voxel_slam_container" --format "{{.Status}}" | grep -q "Up"; then
            log "✅ VoxelSlam容器已启动"
            VOXEL_CONTAINER_ID=$(docker ps -qf "name=voxel_slam_container")
            log "📌 容器ID: ${VOXEL_CONTAINER_ID}"
            popd >/dev/null
            return 0
        fi
        sleep 1
